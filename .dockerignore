# ── Git / CI ──────────────────────────────────────────
.git
.github
.gitignore

# ── Python caches ─────────────────────────────────────
__pycache__
*.py[cod]
*.egg-info

# ── Environments ──────────────────────────────────────
.venv

# ── Test / lint caches ────────────────────────────────
.pytest_cache
.ruff_cache
.mypy_cache
.nox

# ── ML artifacts (not needed in app image) ────────────
mlruns/
mlflow.db
catboost_info/

# ── Data (app uses app/data/ only) ───────────────────
data/raw/
data/processed/
notebooks/

# ── Docs / non-runtime files ─────────────────────────
docs/
*.md
!README.md
*.ipynb
